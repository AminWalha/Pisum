# ── Supabase ────────────────────────────────────────────────────────────────
# From: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Stripe ───────────────────────────────────────────────────────────────────
# From: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_STARTER=price_your_starter_price_id
STRIPE_PRICE_ID_PRO=price_your_pro_price_id
STRIPE_PRICE_ID_EXPERT=price_your_expert_price_id
STRIPE_PRICE_ID_CLINIC=price_your_clinic_price_id

# ── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://pisum.app
