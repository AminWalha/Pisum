  "terms": {
    "a_1": "<img alt=\"Logo\" src=\"https://raw.githubusercontent.com/AminWalha/Pisum/refs/heads/main/logo%20V2.png\"/>\n    PISUM",
    "li_1": "<a href=\"index.html#features\">功能</a>",
    "li_2": "<a href=\"index.html#templates\">模板</a>",
    "li_3": "<a href=\"index.html#pricing\">定价</a>",
    "li_4": "<a href=\"index.html#languages\">语言</a>",
    "li_5": "<a href=\"faq.html\">常见问题</a>",
    "li_6": "<a href=\"documentation.html\">文档</a>",
    "li_7": "<a href=\"contact.html\">联系方式</a>",
    "a_2": "免费开始使用",
    "a_3": "<img alt=\"\" class=\"nav-profile-avatar\" id=\"nav-profile-img\" src=\"\" style=\"display:none\"/>\n<div class=\"nav-profile-avatar-fallback\" id=\"nav-profile-initials\" style=\"display:none\">?</div>\n<div class=\"nav-profile-info\">\n<span class=\"nav-profile-name\" id=\"nav-profile-name\"></span>\n<span class=\"nav-profile-email\" id=\"nav-profile-email\"></span>\n</div>",
    "button_1": "登出",
    "span_1": "法律",
    "h1_1": "使用<br/><em>条款</em>",
    "p_1": "使用 PISUM 即表示您同意这些条件。请仔细阅读。",
    "p_2": "<svg fill=\"none\" height=\"12\" viewbox=\"0 0 12 12\" width=\"12\"><circle cx=\"6\" cy=\"6\" r=\"5\" stroke=\"currentColor\" stroke-width=\"1.2\"></circle><path d=\"M6 4v2.5l1.5 1\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-width=\"1.2\"></path></svg>\n<span id=\"updated\">版本 1.3 — 2026 年 1 月</span>",
    "li_8": "<a href=\"#s1\" id=\"tl1\">1. 同意条款</a>",
    "li_9": "<a href=\"#s2\" id=\"tl2\">2. 使用许可</a>",
    "li_10": "<a href=\"#s3\" id=\"tl3\">3. 医学责任</a>",
    "li_11": "<a href=\"#s4\" id=\"tl4\">4. 数据与隐私</a>",
    "li_12": "<a href=\"#s5\" id=\"tl5\">5. 知识产权</a>",
    "li_13": "<a href=\"#s6\" id=\"tl6\">6. 终止</a>",
    "li_14": "<a href=\"#s7\" id=\"tl7\">7. 责任限制</a>",
    "li_15": "<a href=\"#s8\" id=\"tl8\">8. 适用法律</a>",
    "h2_1": "<span class=\"num\">01</span> <span id=\"s1h\">接受条款</span>",
    "p_3": "本使用条款 (CGU) 规范了对 PISUM SAS 开发的放射科报告软件 PISUM 的访问和使用。",
    "p_4": "通过安装、激活或使用 PISUM，您承认已阅读并无保留地接受这些条款。如果您不接受，请勿使用该软件。",
    "h2_2": "<span class=\"num\">02</span> <span id=\"s2h\">使用许可</span>",
    "p_5": "PISUM SAS 授予用户一项个人的、非排他的、不可转让的、可撤销的许可，在遵守本条款的前提下，在放射科专业活动框架内使用 PISUM 软件。",
    "h3_1": "授予的权利",
    "li_16": "在所订阅计划对应的数量的工作站上安装和使用 PISUM。",
    "li_17": "创建放射科报告供专业使用。",
    "li_18": "针对您的医疗实践自定义内置模板。",
    "h3_2": "限制",
    "li_19": "您不得分发、再授权或转售软件的访问权限。",
    "li_20": "您不得反编译、反汇编或尝试提取源代码。",
    "li_21": "您不得使用 PISUM 开发竞争产品。",
    "h2_3": "<span class=\"num\">03</span> <span id=\"s3h\">医学责任</span>",
    "p_6": "PISUM 是一个<strong>撰写辅助工具</strong>。生成的报告不构成独立的医疗建议，必须由签字和验证报告的放射科医生承担最终责任。",
    "p_7": "提供的模板仅为指示性结构模型。它们由经验丰富的放射科医生制定，但必须由医疗专业人员根据每位患者的具体临床情况进行调整。",
    "h2_4": "<span class=\"num\">04</span> <span id=\"s4h\">数据与隐私</span>",
    "p_8": "患者数据和报告仅存储在您的本地机器上。任何患者数据、报告或医学图像都不会传输到 PISUM SAS 服务器。",
    "p_9": "PISUM SAS 收集的仅涉及您账户和许可管理的必要数据（邮箱、许可密钥、软件版本）。详情请参阅我们的 <a href=\"rgpd.html\">GDPR 隐私政策</a>。",
    "li_22": "账户数据托管在欧盟。",
    "li_23": "患者数据保留在您的本地机器上——我们无法访问。",
    "li_24": "语音听写 (Sally AI) 使用安全云 API 进行实时处理——音频永不存储。",
    "h2_5": "<span class=\"num\">05</span> <span id=\"s5h\">知识产权</span>",
    "p_10": "PISUM、其源代码、112 个模板、Sally AI 听写引擎、图形界面及其所有组件均为 <strong>PISUM SAS</strong> 的专有财产，并受法国及国际知识产权法保护。",
    "p_11": "用户根据模板生成的报告完全属于用户所有。PISUM SAS 不对所产生的医疗内容主张任何权利。",
    "h2_6": "<span class=\"num\">06</span> <span id=\"s6h\">终止</span>",
    "p_12": "您可以随时从您的客户后台取消订阅。终止在当前计费周期结束时生效——您在此日期前仍可访问软件。",
    "p_13": "如遇违反本条款、欺诈或滥用软件的情况，PISUM SAS 有权立即暂停或终止您的访问权，无需事先通知或退款。",
    "h2_7": "<span class=\"num\">07</span> <span id=\"s7h\">责任限制</span>",
    "p_14": "在法律允许的范围内，PISUM SAS 对因使用或无法使用软件导致的任何间接、附带、特殊或后果性损失不承担责任。",
    "p_15": "无论起因为何，PISUM SAS 的总责任额不得超过用户在过去 12 个月中支付的订阅金额。",
    "h2_8": "<span class=\"num\">08</span> <span id=\"s8h\">适用法律与争议解决</span>",
    "p_16": "本条款适用法国法律。争议发生时，双方承诺在诉诸司法前寻求友好解决。若无法达成协议，则巴黎管辖法院拥有唯一管辖权。",
    "p_17": "如对本条款有任何疑问：<a href=\"mailto:MyPisum@Proton.me\">MyPisum@Proton.me</a>",
    "p_18": "© 2026 PISUM. 保留所有权利。",
