    "a_2": "免费开始使用",
    "a_3": "<img alt=\"\" class=\"nav-profile-avatar\" id=\"nav-profile-img\" src=\"\" style=\"display:none\"/>\n<div class=\"nav-profile-avatar-fallback\" id=\"nav-profile-initials\" style=\"display:none\">?</div>\n<div class=\"nav-profile-info\">\n<span class=\"nav-profile-name\" id=\"nav-profile-name\"></span>\n<span class=\"nav-profile-email\" id=\"nav-profile-email\"></span>\n</div>",
    "button_1": "登出",
    "span_1": "合规性",
    "h1_1": "患者数据<br/><em>保护</em>",
    "p_1": "100% 本地架构 · 零云端 · GDPR 第 25 条 · HDS 就绪",
    "p_2": "<svg fill=\"none\" height=\"12\" viewbox=\"0 0 12 12\" width=\"12\"><circle cx=\"6\" cy=\"6\" r=\"5\" stroke=\"currentColor\" stroke-width=\"1.2\"></circle><path d=\"M6 4v2.5l1.5 1\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-width=\"1.2\"></path></svg>\n<span id=\"updated\">更新于：2026 年 1 月</span>",
    "li_8": "<a href=\"#s1\" id=\"tl1\">1. 收集的数据</a>",
    "li_9": "<a href=\"#s2\" id=\"tl2\">2. 离线架构</a>",
    "li_10": "<a href=\"#s3\" id=\"tl3\">3. 主权与遥测</a>",
