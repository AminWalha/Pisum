# ── Supabase ────────────────────────────────────────────────────────────────
# From: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Lemon Squeezy ────────────────────────────────────────────────────────────
# From: https://app.lemonsqueezy.com → Settings → API
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
LEMONSQUEEZY_WEBHOOK_SECRET=your_lemonsqueezy_webhook_secret
# From: https://app.lemonsqueezy.com → Settings → Stores → your store ID
LEMONSQUEEZY_STORE_ID=your_store_id
# Variant IDs from your product variants in Lemon Squeezy
LS_VARIANT_ID_STARTER=your_starter_monthly_variant_id
LS_VARIANT_ID_STARTER_ANNUAL=your_starter_annual_variant_id
LS_VARIANT_ID_PRO=your_pro_monthly_variant_id
LS_VARIANT_ID_PRO_ANNUAL=your_pro_annual_variant_id
LS_VARIANT_ID_EXPERT=your_expert_monthly_variant_id
LS_VARIANT_ID_EXPERT_ANNUAL=your_expert_annual_variant_id
LS_VARIANT_ID_CLINIC=your_clinic_monthly_variant_id
LS_VARIANT_ID_CLINIC_ANNUAL=your_clinic_annual_variant_id
# Extra-seat add-on for Clinic (+€69/seat/month) — create a separate per-unit recurring variant
LS_VARIANT_ID_CLINIC_EXTRA_SEAT=your_clinic_extra_seat_variant_id

# ── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://pisum.app
