    "span_6": "모달리티",
    "span_7": "최근",
    "span_8": "언어",
    "h4_1": "흉부 CT — 표준 프로토콜",
    "span_9": "CT · THORAX",
    "label_1": "환자",
    "span_10": "M. Laurent, 58세",
    "label_2": "날짜",
