  "documentation": {
    "a_1": "<img alt=\"Logo\" src=\"logo V2.png\"/>\n    PISUM",
    "li_1": "<a href=\"index.html#features\">기능</a>",
    "li_2": "<a href=\"index.html#templates\">템플릿</a>",
    "li_3": "<a href=\"index.html#pricing\">요금제</a>",
    "li_4": "<a href=\"index.html#languages\">언어</a>",
    "li_5": "<a href=\"faq.html\">FAQ</a>",
    "li_6": "<a href=\"documentation.html\">문서</a>",
    "li_7": "<a href=\"contact.html\">문의</a>",
    "a_2": "무료 시작하기",
    "a_3": "<img alt=\"\" class=\"nav-profile-avatar\" id=\"nav-profile-img\" src=\"\" style=\"display:none\"/>\n<div class=\"nav-profile-avatar-fallback\" id=\"nav-profile-initials\" style=\"display:none\">?</div>\n<div class=\"nav-profile-info\">\n<span class=\"nav-profile-name\" id=\"nav-profile-name\"></span>\n<span class=\"nav-profile-email\" id=\"nav-profile-email\"></span>\n</div>",
    "button_1": "로그아웃",
    "span_1": "지원",
    "h1_1": "영상의학<br/><em>판독 소프트웨어</em> 사용법",
    "p_1": "영상의학 판독 템플릿, AI 음성 받아쓰기 설정 및 Pisum을 이용한 자동화 보고서 작성 단계별 가이드입니다.",
    "li_8": "<a href=\"#installation\" id=\"tl1\">설치</a>",
    "li_9": "<a href=\"#templates\" id=\"tl2\">템플릿 사용</a>",
    "li_10": "<a href=\"#dictation\" id=\"tl3\">AI 음성 받아쓰기</a>",
    "li_11": "<a href=\"#export\" id=\"tl4\">RIS/PACS 내보내기</a>",
    "li_12": "<a href=\"#translation\" id=\"tl7\">판독문 번역 <span style=\"font-size:0.58rem;font-weight:700;background:linear-gradient(135deg,#3b6ef8,#7c5af0);color:#fff;padding:0.1rem 0.32rem;border-radius:3px;margin-left:4px;letter-spacing:0.04em\">신규</span></a>",
    "li_13": "<a href=\"#lan-sync\" id=\"tl6\">LAN 네트워크 동기화</a>",
    "li_14": "<a href=\"#support\" id=\"tl5\">기술 지원 문의</a>",
    "h2_1": "<span class=\"num\">01</span> <span id=\"s1h\">설치</span>",
    "p_2": "Pisum은 Windows용 경량 데스크톱 애플리케이션입니다. 복잡한 IT 구성이 필요하지 않습니다.",
    "li_15": "환영 이메일에 제공된 링크를 통해 최신 설치 파일을 다운로드하세요.",
    "li_16": "다운로드한 <code>.exe</code> 파일을 더블 클릭하세요.",
    "li_17": "화면의 지침을 따르세요. 일반적으로 관리자 권한은 필요하지 않습니다.",
    "span_2": "Pisum은 기본적으로 완전히 오프라인으로 작동합니다. 환자 데이터는 클라우드 서버로 절대 전송되지 않습니다.",
    "h2_2": "<span class=\"num\">02</span> <span id=\"s2h\">템플릿 사용</span>",
    "p_3": "Pisum은 5개 모달리티(CT, MRI, 초음파, X-Ray, 중재적 시술)를 아우르는 112개의 전문가 템플릿을 제공합니다.",
    "h3_1": "템플릿 선택",
    "p_4": "왼쪽 패널에서 모달리티별 폴더(예: CT > 복부-골반)를 탐색하거나 상단 검색창을 사용하여 특정 프로토콜을 빠르게 찾으세요.",
    "span_3": "내장된 모든 템플릿을 수정하거나 '새 템플릿'을 클릭하여 나만의 템플릿을 생성할 수 있습니다. 생성된 템플릿은 귀하의 프로필에 로컬로 저장됩니다.",
    "h2_3": "<span class=\"num\">03</span> <span id=\"s3h\">AI 음성 받아쓰기</span>",
    "p_5": "내장된 Sally AI 엔진을 통해 23개 언어로 핸즈프리 받아쓰기가 가능하며, 영상의학 용어를 자동으로 교정합니다.",
    "li_18": "🎙️ 아이콘을 클릭하거나 <code>F4</code> 키를 눌러 녹음을 시작/중지하세요.",
    "li_19": "받아쓰기 바의 드롭다운 메뉴에서 원하는 언어를 선택하세요.",
    "h2_4": "<span class=\"num\">04</span> <span id=\"s4h\">RIS/PACS 내보내기</span>",
    "p_6": "Pisum은 복잡한 통합 과정 없이 기존 시스템에 쉽게 연동되도록 설계된 보조 도구입니다.",
    "h3_2": "복사 및 붙여넣기 (권장)",
    "p_7": "판독 완료 후 '판독문 복사'(또는 <code>Ctrl+C</code>)를 클릭하세요. 텍스트 형식이 그대로 유지되어 RIS 또는 PACS 편집기로 바로 붙여넣을 수 있습니다.",
    "h3_3": "Word 내보내기",
    "p_8": "'DOCX로 내보내기' 버튼을 사용하면 전문적으로 서식이 지정된 문서를 저장할 수 있으며, 환자에게 직접 보고서를 제공하는 개인 병원에 적합합니다.",
    "h2_5": "<span class=\"num\">07</span> 판독문 번역 <span style=\"font-size:0.6rem;font-weight:700;background:linear-gradient(135deg,#3b6ef8,#7c5af0);color:#fff;padding:0.15rem 0.45rem;border-radius:4px;vertical-align:middle;margin-left:6px;letter-spacing:0.05em\">신규 · v2.9.8</span>",
    "p_9": "판독문 번역 기능을 사용하면 작성 완료된 영상의학 보고서를 클릭 한 번으로 다른 언어로 변환할 수 있습니다. 임상 용어와 보고서 구조는 그대로 유지됩니다. <strong>Pro</strong>, <strong>Expert</strong>, <strong>Clinic</strong> 요금제에서 사용 가능합니다.",
    "h3_4": "사용 방법",
    "li_20": "작업 목록에서 작성 완료된 판독문을 엽니다.",
    "li_21": "도구 모음에서 <strong>판독문 번역</strong>을 클릭하세요 (또는 <code>Ctrl+T</code> 단축키 사용).",
    "li_22": "드롭다운에서 대상 언어를 선택하세요 (23개 언어 지원).",
    "li_23": "<strong>번역</strong>을 클릭하세요. 번역된 보고서가 몇 초 내에 나란히 표시됩니다.",
    "li_24": "내용을 검토한 후 평소처럼 PDF나 Word로 내보내세요.",
    "span_4": "원문 보고서는 절대 덮어쓰기 되지 않습니다. 번역 시 동일한 환자 검사에 연결된 별도의 복사본이 생성되며, 두 버전 모두 작업 목록에 나타납니다.",
    "h3_5": "지원 언어",
    "p_10": "프랑스어, 스페인어, 독일어, 아랍어, 포르투갈어, 이탈리아어, 네덜란드어, 폴란드어 등을 포함하여 PISUM 인터페이스에서 지원하는 23개 언어 모두 번역 대상으로 사용 가능합니다.",
    "span_5": "Pro: 월 100회 번역 · Expert: 무제한 · Clinic: 무제한. 번역 기능은 활성 인터넷 연결이 필요합니다.",
    "h2_6": "<span class=\"num\">06</span> LAN 네트워크 공유",
    "p_11": "<strong>Expert</strong> 및 <strong>Clinic</strong> 요금제에서 사용 가능합니다. 인터넷이나 클라우드 스토리지, 별도의 서버 설정 없이 병원 내 여러 워크스테이션 간에 환자 데이터베이스를 공유하세요.",
    "h3_6": "작동 원리",
    "p_12": "모든 워크스테이션이 공유 네트워크 폴더(NAS, Windows SMB 공유 또는 매핑된 드라이브)에 저장된 단일 SQLite 데이터베이스 파일을 참조합니다. PISUM은 WAL 잠금을 사용하여 동시 접속을 자동으로 처리합니다. 환자 데이터는 네트워크를 통하기 전 <strong>AES-256-GCM</strong> 방식으로 종단간 암호화됩니다.",
    "h3_7": "요금제 제한",
    "li_25": "<strong>Expert</strong> — 1개 사이트, 최대 3개 워크스테이션 (동일 건물)",
    "li_26": "<strong>Clinic</strong> — 다중 사이트, 무제한 워크스테이션",
    "h3_8": "필수 요구사항",
    "li_27": "모든 워크스테이션에서 읽기/쓰기가 가능한 공유 네트워크 폴더(NAS, Windows SMB 공유 또는 <code>Z:\\</code> 같은 매핑 드라이브)",
    "li_28": "안정적인 파일 잠금을 위해 SMB 3.0 이상 권장",
    "li_29": "모든 PC는 동일한 LAN 또는 VPN에 연결되어야 함",
    "h3_9": "단계별 설정",
    "li_30": "서버나 NAS에 공유 폴더를 생성하고(예: <code>\\\\SERVER\\PISUM</code>), 모든 워크스테이션에 읽기/쓰기 권한을 부여하세요.",
    "li_31": "첫 번째 워크스테이션에서 PISUM을 실행하고 <strong>설정 → 로컬 네트워크(LAN)</strong>로 이동하세요.",
    "li_32": "<strong>네트워크 경로</strong>(예: <code>\\\\SERVER\\PISUM</code> 또는 <code>Z:\\PISUM</code>), 고유한 <strong>워크스테이션 ID</strong>(예: <code>WORKSTATION-01</code>), 그리고 <strong>병원 이름</strong>을 입력하세요.",
    "li_33": "<strong>네트워크 비밀번호</strong>(최소 6자)를 입력하세요. 모든 워크스테이션에서 <em>정확히 동일한 비밀번호</em>를 사용하게 됩니다.",
    "li_34": "<strong>활성화</strong>를 클릭하세요. 배지가 <em>● 연결됨</em>으로 바뀌고 네트워크 폴더에 공유 데이터베이스가 자동으로 생성됩니다.",
    "li_35": "다른 모든 워크스테이션에서 2~5단계를 반복하세요(동일 경로, 동일 비밀번호, 다른 워크스테이션 ID 사용).",
    "span_6": "\"최대 워크스테이션 수 초과\" 메시지가 뜨면 Clinic 요금제로 업그레이드하거나 공유 폴더 내 <code>.workstations.json</code> 파일을 열어 사용하지 않는 워크스테이션 항목을 제거하세요.",
    "h3_10": "보안",
    "li_36": "모든 환자 데이터는 공유 폴더에 기록되기 전 <strong>AES-256-GCM</strong>으로 암호화됩니다. 원본 데이터베이스 파일은 키 없이는 읽을 수 없습니다.",
    "li_37": "암호화 키(<code>.enc_network_key</code>)는 공유 폴더에 저장되며, 네트워크 비밀번호로 보호됩니다(PBKDF2-HMAC-SHA256, 60만 회 반복).",
    "li_38": "네트워크 비밀번호는 디스크에 <em>절대 저장되지 않으며</em>, 세션 유지 시간 동안 메모리에만 보관됩니다.",
    "li_39": "모든 접근, 수정, 내보내기 활동은 타임스탬프와 워크스테이션 ID가 포함된 GDPR 준수 감사 로그에 기록됩니다.",
    "h3_11": "문제 해결",
    "li_40": "<strong>배지가 \"연결 해제됨\" 상태 유지</strong> — 공유 폴더 경로가 올바른지, 이 PC에서 접근 가능한지 확인하세요(Windows 탐색기에서 먼저 열어보세요).",
    "li_41": "<strong>\"잘못된 비밀번호\" 오류</strong> — 네트워크 비밀번호는 모든 워크스테이션에서 동일해야 합니다. 대소문자를 구분하여 주의 깊게 다시 입력하세요.",
    "li_42": "<strong>데이터베이스가 느리거나 잠김</strong> — NAS나 공유 시스템이 SMB 3.0을 지원하는지 확인하세요. 일부 구형 NAS 펌웨어는 SQLite WAL 잠금을 제대로 지원하지 않습니다. 펌웨어를 업데이트하거나 Windows 공유 폴더로 전환하세요.",
    "h2_7": "<span class=\"num\">05</span> <span id=\"s5h\">기술 지원 문의</span>",
    "p_13": "이 문서에서 다루지 않은 문제가 발생하면, 저희 팀이 도움을 드릴 준비가 되어 있습니다.",
    "p_14": "<a href=\"contact.html\" id=\"s5a\" style=\"font-weight: 600;\">문의 페이지 열기 →</a>",
    "p_15": "© 2026 PISUM. 모든 권리 보유.",
